# 🚀 Phase 2: High-Accuracy Training Configuration
model = YOLO("yolov8n.pt") 

results = model.train(
    data=f"{OUTPUT_ROOT}/dataset.yaml",
    epochs=150,           # Increased epochs to give it more time to learn colors
    imgsz=640,            # Higher resolution helps the model see texture
    batch=16,
    
   # --- SPECIAL FIXES FOR COLOR CONFUSION ---
    
    # 1. Label Smoothing: Tells the model "Don't be 100% sure." 
    # This stops it from over-confidently picking Red when it might be Yellow.
    label_smoothing=0.1, 
    
    # 2. Adjusting HSV (Color) Augmentation:
    # We lower these slightly so the model doesn't get confused by 
    # fake colors created during training.
    hsv_h=0.015, # Slight hue shift
    hsv_s=0.4,   # Don't make the yellow too saturated (which looks red)
    hsv_v=0.3,   # Keep brightness realistic
    

