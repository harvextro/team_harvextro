# 1. DIRECT PATH TO YOUR MODEL (No more NameErrors!)
# We are using the v1-2 path you provided
model_path = '/kaggle/working/harvextro_yolov8/runs/harvextro_final_v1-2/weights/best.pt'
best_model = YOLO(model_path)

# 2. DEFINE NECESSARY VARIABLES
# Make sure these paths match your HarveXtro project folder
OUTPUT_ROOT = "/kaggle/working/harvextro_yolov8"
yaml_path = f"{OUTPUT_ROOT}/dataset.yaml"
RUN_NAME = "harvextro_final_v1_2" # Name for this evaluation run
IMG_SIZE = 640 
CLASSES = ['green_chili', 'red_chili', 'yellow_chili']

# ─── EVALUATE on TEST SET ───────────────────────────────────────
metrics = best_model.val(
    data    = yaml_path,
    split   = "test",
    imgsz   = IMG_SIZE,
    conf    = 0.25,
    iou     = 0.45,
    plots   = True,
    project = f"{OUTPUT_ROOT}/runs",
    name    = f"{RUN_NAME}_eval",
)

# ─── PERFORMANCE REPORT ─────────────────────────────────────────
print("\n" + "═"*25 + " HARVEXTRO PERFORMANCE REPORT " + "═"*25)
print(f"  Overall mAP@50 : {metrics.box.map50:.4f}")
print(f"  Precision      : {metrics.box.mp:.4f}")
print(f"  Recall         : {metrics.box.mr:.4f}")

print("\n--- Per-Class Analysis ---")
for i, cls in enumerate(CLASSES):
    print(f"  [{cls:15s}]  AP50: {metrics.box.ap50[i]:.4f}")

# ─── INFERENCE TEST ─────────────────────────────────────────────
test_images = list((Path(OUTPUT_ROOT) / "test" / "images").glob("*.jpg"))[:5]

if test_images:
    results_list = best_model.predict(
        source  = test_images,
        conf    = 0.25,
        imgsz   = IMG_SIZE,
        save    = True,
        project = f"{OUTPUT_ROOT}/runs",
        name    = f"{RUN_NAME}_predict",
    )
